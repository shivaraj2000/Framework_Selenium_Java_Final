<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite parallel="tests" name="MySuite">

    <groups>
        <run>
            <include name="ErrorValidation"/>
        </run>
    </groups>
    <test thread-count="2" name="Submit Order Test">
        <classes>
            <class name="com.example.SubmitOrderTest"/>
        </classes>
    </test>
    <test thread-count="2" name="Error Validation Test">
        <classes>
            <class name="com.example.ErrorValidation"/>
        </classes>
    </test>
</suite>
